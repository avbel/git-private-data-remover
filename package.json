{
  "name": "git-private-data-remover",
  "version": "1.0.0",
  "description": "CLI tool to remove accidentally committed private data from git history",
  "module": "src/index.ts",
  "type": "module",
  "scripts": {
    "start": "bun run src/index.ts",
    "test": "bun test",
    "lint": "bunx oxlint .",
    "lint:fix": "bunx oxlint . --fix",
    "format": "bunx biome format .",
    "format:fix": "bunx biome format --write .",
    "typecheck": "bunx tsc --noEmit",
    "prepare": "git rev-parse --git-dir > /dev/null 2>&1 && lefthook install || true"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "latest",
    "lefthook": "^2.1.6",
    "oxlint": "^1.61.0",
    "typescript": "6.0.3"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "chalk": "^5.4.0"
  }
}
